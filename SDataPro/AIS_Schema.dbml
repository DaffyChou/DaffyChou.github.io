// =====================================================
// AIS 智慧監控平台 — Schema (DBML)
// 對應 SDataPro/AIS_Platform_Demo.html
// 詳細欄位語意請見 SDataPro/AIS_Database_Design.md
//
// 視覺化：
//   - 線上：貼到 https://dbdiagram.io 或 https://dbml.dbdiagram.io
//   - 本機：npm i -g @dbml/cli
//           dbml2sql AIS_Schema.dbml --postgres > AIS_Schema.sql
//           dbml-renderer -i AIS_Schema.dbml -o AIS_Schema.svg
// =====================================================

Project ais_platform {
  database_type: 'PostgreSQL'
  Note: 'AIS 戰情室主資料庫；位置/CI/XTD 為 TimescaleDB hypertable'
}

// ───── Enums ─────
Enum vessel_status {
  underway
  anchored
  berthed
  approaching
  departing
  ais_issue
}

Enum ais_time_source {
  NTP
  AIS1
  AIS17
  SYS
}

Enum ais_time_conf {
  H
  M
  L
}

Enum source_type {
  terrestrial
  satellite
  synthesized_dr
}

Enum congestion_level {
  normal
  light
  moderate
  high
}

Enum data_conf_level {
  high
  med
  low
  insuf
}

Enum cpa_level {
  RED
  AMBER
}

Enum cpa_status {
  new
  ack
  monitoring
  resolved
  closed
}

Enum encounter_type {
  head_on
  crossing
  overtaking
}

Enum audit_action {
  New
  Notified
  Viewed
  Acknowledged
  Comment
  Resolved
  Closed
  Playback
}

Enum plan_status {
  pending
  active
  superseded
  archived
}

Enum quality_level {
  high
  med
  low
  insuf
}

Enum behavior_type {
  underway
  anchored
  approaching
  unknown
}

Enum disappear_state {
  live
  gap
  exited
}

Enum voyage_status {
  planned
  underway
  completed
  cancelled
}

Enum trigger_type {
  cpa
  ais_gap
  port_congestion
  route_deviation
}

Enum delivery_status {
  queued
  sent
  failed
  bounced
}

Enum user_role {
  admin
  marine_mgr
  operator
  viewer
  system
}

// ───── Master Data ─────
Table organizations {
  id uuid [pk]
  name varchar(80) [not null]
  created_at timestamptz [default: `now()`]
}

Table users {
  id uuid [pk]
  org_id uuid [ref: > organizations.id, not null]
  email varchar(120) [unique, not null]
  name varchar(80) [not null]
  role user_role [not null]
  created_at timestamptz [default: `now()`]
  last_login_at timestamptz
}

Table vessels {
  mmsi bigint [pk]
  imo int [unique]
  name varchar(50)
  callsign varchar(10)
  ship_type smallint
  ship_type_label varchar(30)
  flag varchar(2)
  length_m numeric(5,1)
  width_m numeric(4,1)
  dwt int
  first_seen_at timestamptz
  last_seen_at timestamptz
  is_active boolean [default: true]
  Indexes {
    name [name: 'idx_vessels_name_trgm', type: gin]
    last_seen_at
  }
}

Table fleet_ownership {
  org_id uuid [ref: > organizations.id]
  mmsi bigint [ref: > vessels.mmsi]
  since date [not null]
  until date
  Indexes {
    (org_id, mmsi, since) [pk]
  }
}

Table ports {
  code varchar(10) [pk]
  name_zh varchar(50)
  name_en varchar(80)
  country varchar(2)
  region varchar(30)
  lat numeric(9,6)
  lon numeric(9,6)
  area_geom "geography(POLYGON,4326)"
  anchorage_geom "geography(POLYGON,4326)"
  offshore_lat_offset numeric(5,2)
  offshore_lon_offset numeric(5,2)
  Indexes {
    area_geom [type: gist]
    region
  }
}

// ───── Voyages ─────
Table voyages {
  id uuid [pk]
  mmsi bigint [ref: > vessels.mmsi, not null]
  voyage_code varchar(20)
  origin_port varchar(10) [ref: > ports.code]
  dest_port varchar(10) [ref: > ports.code]
  eta_original timestamptz
  eta_dynamic timestamptz
  draught_m numeric(4,2)
  started_at timestamptz
  ended_at timestamptz
  status voyage_status
  Indexes {
    (mmsi, started_at) [name: 'idx_voyages_mmsi_started']
    status
  }
}

// ───── Position Time-series (TimescaleDB hypertable) ─────
Table vessel_positions {
  mmsi bigint [ref: > vessels.mmsi, not null]
  ts timestamptz [not null]
  received_at timestamptz [not null]
  lat numeric(9,6) [not null]
  lon numeric(9,6) [not null]
  geom "geography(POINT,4326)"
  sog numeric(4,1)
  cog numeric(4,1)
  heading numeric(4,1)
  nav_status smallint
  rot numeric(5,1)
  source source_type
  source_station varchar(50)
  accuracy smallint
  is_dr boolean [default: false]
  raw_msg_id uuid
  Indexes {
    (mmsi, ts) [pk, name: 'pk_positions']
    geom [type: gist]
    ts [name: 'idx_positions_ts']
  }
  Note: 'TimescaleDB hypertable, chunk 1 day, retention 180 days'
}

Table ais_messages_raw {
  id uuid [pk]
  ts timestamptz [not null]
  msg_type smallint
  mmsi bigint
  raw_payload text [not null]
  source_station varchar(50)
  Indexes {
    (mmsi, ts)
    ts
  }
  Note: 'Optional cold storage; retention 30 days'
}

// ───── AIS Quality ─────
Table ais_quality_metrics {
  mmsi bigint [ref: > vessels.mmsi]
  window_start timestamptz
  window_end timestamptz
  completeness numeric(3,2)
  position_continuity numeric(3,2)
  update_interval_ms int
  time_source ais_time_source
  time_confidence ais_time_conf
  rtt_ms int
  anomaly_type varchar(40)
  score smallint
  Indexes {
    (mmsi, window_start) [pk]
  }
}

// ───── Vessel Observations (foreign vessels seen by own fleet) ─────
Table vessel_observations {
  id uuid [pk]
  foreign_mmsi bigint [ref: > vessels.mmsi, not null]
  observer_mmsi bigint [ref: > vessels.mmsi, not null]
  first_seen_at timestamptz
  last_seen_at timestamptz
  last_range_nm numeric(4,1)
  update_interval_ms int
  field_completeness numeric(3,2)
  behavior behavior_type
  disappear_state disappear_state
  confidence numeric(3,2)
  quality_level quality_level
  Indexes {
    foreign_mmsi
    observer_mmsi
    last_seen_at
  }
}

// ───── Ports & Congestion ─────
Table port_congestion {
  port_code varchar(10) [ref: > ports.code]
  ts timestamptz
  ci numeric(3,2)
  level congestion_level
  data_confidence data_conf_level
  own_vessels smallint
  foreign_vessels smallint
  avg_wait_hours numeric(4,1)
  eta_impact boolean
  training_samples int
  zone_confidence numeric(3,2)
  Indexes {
    (port_code, ts) [pk]
  }
  Note: 'TimescaleDB hypertable, retention 2 years'
}

Table port_calls {
  id uuid [pk]
  mmsi bigint [ref: > vessels.mmsi]
  port_code varchar(10) [ref: > ports.code]
  voyage_id uuid [ref: > voyages.id]
  arrival_ts timestamptz
  berth_ts timestamptz
  depart_ts timestamptz
  wait_hours numeric(4,1)
  Indexes {
    (port_code, arrival_ts)
    mmsi
  }
}

// ───── CPA Events ─────
Table cpa_events {
  id varchar(16) [pk, note: 'EV-001 format']
  created_at timestamptz [not null]
  resolved_at timestamptz
  level cpa_level
  status cpa_status
  own_mmsi bigint [ref: > vessels.mmsi]
  target_mmsi bigint [ref: > vessels.mmsi]
  cpa_nm numeric(4,2)
  tcpa_min numeric(5,1)
  confidence smallint
  dr_seconds int
  is_dr boolean
  bearing numeric(4,1)
  range_nm numeric(4,1)
  area varchar(80)
  own_sog numeric(4,1)
  target_sog numeric(4,1)
  encounter_angle numeric(4,1)
  encounter_type encounter_type
  data_confidence numeric(3,2)
  push_channels jsonb
  Indexes {
    (own_mmsi, created_at)
    status
    level
    created_at
  }
}

Table cpa_event_snapshots {
  event_id varchar(16) [ref: > cpa_events.id]
  ts timestamptz
  own_lat numeric(9,6)
  own_lon numeric(9,6)
  target_lat numeric(9,6)
  target_lon numeric(9,6)
  cpa_nm numeric(4,2)
  tcpa_min numeric(5,1)
  is_cpa_point boolean
  Indexes {
    (event_id, ts) [pk]
  }
  Note: 'TimescaleDB hypertable, retention 365 days'
}

Table audit_log {
  id varchar(16) [pk, note: 'AUD-001']
  event_id varchar(16) [ref: > cpa_events.id]
  action audit_action
  operator_user_id uuid [ref: > users.id]
  operator_role varchar(30)
  status_before varchar(20)
  status_after varchar(20)
  comment text
  ts timestamptz
  Indexes {
    event_id
    ts
    operator_user_id
  }
}

// ───── Passage Plans ─────
Table passage_plans {
  id uuid [pk]
  voyage_id uuid [ref: > voyages.id]
  mmsi bigint [ref: > vessels.mmsi]
  from_port varchar(10) [ref: > ports.code]
  to_port varchar(10) [ref: > ports.code]
  active_version_id uuid
  xtd_max_nm numeric(4,2)
}

Table plan_versions {
  id uuid [pk]
  plan_id uuid [ref: > passage_plans.id]
  version varchar(10)
  status plan_status
  source varchar(30)
  created_at timestamptz
  effective_at timestamptz
  summary text
  Indexes {
    plan_id
    status
  }
}

Ref: passage_plans.active_version_id > plan_versions.id

Table waypoints {
  id uuid [pk]
  plan_version_id uuid [ref: > plan_versions.id]
  seq smallint
  name varchar(50)
  lat numeric(9,6)
  lon numeric(9,6)
  geom "geography(POINT,4326)"
  speed_kn numeric(4,1)
  xtd_limit_nm numeric(4,2)
  eta_at timestamptz
  passed_at timestamptz
  Indexes {
    (plan_version_id, seq)
    geom [type: gist]
  }
}

Table xtd_records {
  plan_version_id uuid [ref: > plan_versions.id]
  ts timestamptz
  xtd_nm numeric(5,2)
  current_waypoint_seq smallint
  Indexes {
    (plan_version_id, ts) [pk]
  }
  Note: 'TimescaleDB hypertable, retention 365 days'
}

Table deviation_events {
  id uuid [pk]
  plan_version_id uuid [ref: > plan_versions.id]
  started_at timestamptz
  ended_at timestamptz
  peak_xtd_nm numeric(5,2)
  duration_min int
  cause varchar(40)
  Indexes {
    plan_version_id
    started_at
  }
}

// ───── Notifications ─────
Table notification_rules {
  id uuid [pk]
  org_id uuid [ref: > organizations.id]
  name varchar(80)
  trigger_type trigger_type
  conditions jsonb
  channels jsonb
  cooldown_min int
  enabled boolean [default: true]
}

Table notifications {
  id uuid [pk]
  rule_id uuid [ref: > notification_rules.id]
  event_id varchar(16) [ref: > cpa_events.id]
  channel varchar(20)
  recipient varchar(120)
  payload jsonb
  sent_at timestamptz
  delivery_status delivery_status
  error text
  Indexes {
    sent_at
    event_id
    delivery_status
  }
}
